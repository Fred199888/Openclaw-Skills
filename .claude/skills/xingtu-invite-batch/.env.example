# 巨量星图邀约参数配置
#
# 全局认证放在 ~/.claude/skills/xhs-global.env：
#   XINGTU_COOKIE="..."
#   XINGTU_CSRF_TOKEN="..."
#   FEISHU_APP_ID=xxx
#   FEISHU_APP_SECRET=xxx
#
# 邀约参数（本地配置）：
XINGTU_PRODUCT_NAME=Second Me
XINGTU_PRODUCT_INFORMATION=Second Me
XINGTU_BUDGET=1000
XINGTU_FIRST_CLASS_CATEGORY=1928
XINGTU_SECOND_CLASS_CATEGORY=192801
XINGTU_PROMOTION_TARGET=1
XINGTU_TASK_CATEGORY=1
XINGTU_EXPIRATION_DAYS=7

# 筛选参数
XINGTU_MIN_FOLLOWERS=10000
XINGTU_INVITE_TOTAL=20
XINGTU_INVITE_DELAY_MIN=0.5
XINGTU_INVITE_DELAY_MAX=2.0
