# ============================================================
# XHS + Xingtu 全局认证参数
# 使用方法：复制本文件为 xhs-global.env，填入实际值
#   cp xhs-global.env.example xhs-global.env
# ============================================================

# --- 小红书蒲公英认证（所有 xhs-* skill 共享）---
# 获取方式：登录 pgy.xiaohongshu.com → F12 → Network → 复制任意请求的 Headers
XHS_COOKIE=
XHS_X_S=
XHS_X_S_COMMON=
XHS_X_T=
XHS_BRAND_USER_ID=
XHS_TRACK_ID=

# --- 巨量星图认证（所有 xingtu-* skill 共享）---
# 获取方式：登录 star.toutiao.com → F12 → Network → 复制任意请求的 Cookie 和 x-csrf-token
XINGTU_COOKIE=
XINGTU_CSRF_TOKEN=

# --- 飞书 app 认证（KOL 同步、bitable 操作等）---
# 获取方式：飞书开放平台 → 应用管理 → App ID / App Secret
FEISHU_APP_ID=
FEISHU_APP_SECRET=
