# 巨量星图 KOL 抓取 - 配置模板
#
# 全局认证参数放在 ~/.claude/skills/xhs-global.env：
#   XINGTU_COOKIE="..."         # 从浏览器复制的完整 cookie
#   XINGTU_CSRF_TOKEN="..."     # x-secsdk-csrf-token header
#   FEISHU_APP_ID=xxx
#   FEISHU_APP_SECRET=xxx
#
# 本地配置（创建飞书表后填入）：
XINGTU_KOL_APP_TOKEN=
XINGTU_KOL_TABLE_ID=

# 备份目录（可选）
XINGTU_BACKUP_DIR=./output/backups
